## For Local Development (if running backend locally)
# VITE_API_URL=http://localhost:5000/api

# For Production (Railway backend)
VITE_API_URL=https://quran-acadamy-crm-production.up.railway.app/api

# Zoom SDK Configuration (REQUIRED for Zoom meetings)
# Get these from your Zoom App Marketplace credentials
VITE_ZOOM_SDK_KEY=your_zoom_sdk_key_here
VITE_ZOOM_SDK_SECRET=your_zoom_sdk_secret_here

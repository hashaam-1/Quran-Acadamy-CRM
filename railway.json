{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm install && npm start",
    "healthcheckPath": "/api/health",
    "rootDirectory": "Backend",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckTimeout": 30000,
    "healthcheckInterval": 5000
  }
}

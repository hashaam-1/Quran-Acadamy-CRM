# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Frontend URL for CORS and email links
FRONTEND_URL=https://your-frontend-url.com

# JWT Secret (Generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# Zoom Meeting SDK Credentials
ZOOM_SDK_KEY=your_zoom_sdk_key_here
ZOOM_SDK_SECRET=your_zoom_sdk_secret_here
ZOOM_SECRET_TOKEN=your_zoom_secret_token_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM_NAME=Quran Academy CRM

# Cloudflare R2 Configuration (for file uploads)
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_r2_endpoint.r2.cloudflarestorage.com
R2_BUCKET_NAME=quran-academy-syllabus
R2_PUBLIC_URL=https://your_r2_public_url.r2.dev

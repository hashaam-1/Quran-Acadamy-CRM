# Production Environment Variables for Railway
# Copy these to Railway Dashboard → Variables (NOT as a file)

# Server (Railway sets PORT automatically, but you can override)
NODE_ENV=production

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/quran_academy_crm?retryWrites=true&w=majority

# Frontend URL (Update with your deployed frontend URL)
FRONTEND_URL=https://your-frontend-url.netlify.app

# Email Configuration (Gmail App Password - NO SPACES!)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your16charapppassword
EMAIL_FROM_NAME=Quran Academy CRM

# Note: For Railway deployment, add these as environment variables in the dashboard
# Do NOT create a .env file in Railway - use the Variables tab
